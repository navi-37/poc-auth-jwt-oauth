@model List<TenantResponse>
@{
    ViewData["Title"] = "Tenants";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="mb-0">Tenants</h4>
    <a asp-action="Create" class="btn btn-dark btn-sm">+ Nuevo</a>
</div>

@if (!Model.Any())
{
    <p class="text-muted">No hay tenants registrados.</p>
}
else
{
    <table class="table table-bordered table-sm">
        <thead class="table-dark">
            <tr>
                <th>Slug</th>
                <th>Nombre</th>
                <th>Creado</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var tenant in Model)
            {
                <tr>
                    <td><code>@tenant.Slug</code></td>
                    <td>@tenant.Name</td>
                    <td>@tenant.CreatedAt.ToString("dd/MM/yyyy")</td>
                    <td class="text-end">
                        <form asp-action="Delete" asp-route-id="@tenant.Id" method="post"
                              onsubmit="return confirm('¿Eliminar @tenant.Slug?')">
                            <button type="submit" class="btn btn-outline-danger btn-sm">Eliminar</button>
                        </form>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}
