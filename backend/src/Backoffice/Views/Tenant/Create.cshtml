@model CreateTenantViewModel
@{
    ViewData["Title"] = "Nuevo tenant";
}

<div class="row">
    <div class="col-md-5">
        <h4 class="mb-4">Nuevo tenant</h4>
        <form asp-action="Create" method="post">
            <div class="mb-3">
                <label asp-for="Slug" class="form-label">Slug</label>
                <div class="input-group">
                    <input asp-for="Slug" class="form-control" placeholder="pencaamigos" />
                    <span class="input-group-text text-muted">.tupenca.uy</span>
                </div>
                <span asp-validation-for="Slug" class="text-danger small"></span>
                <div class="form-text">Solo minúsculas, números y guiones.</div>
            </div>
            <div class="mb-4">
                <label asp-for="Name" class="form-label">Nombre</label>
                <input asp-for="Name" class="form-control" placeholder="Penca Amigos" />
                <span asp-validation-for="Name" class="text-danger small"></span>
            </div>
            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-dark">Crear</button>
                <a asp-action="Index" class="btn btn-outline-secondary">Cancelar</a>
            </div>
        </form>
    </div>
</div>
